# ════════════════════════════════════════════════════════════════════
#  ITPlus — Plataforma de Consulta Inteligente
#  Copia como ".env" en la raíz del proyecto
# ════════════════════════════════════════════════════════════════════

# App
APP_NAME=ITPlus Consulta Inteligente
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
DEBUG=true

# PostgreSQL + pgvector
DATABASE_URL=postgresql://itplus:itplus@localhost:5432/consulta_db

# Redis (Celery worker)
REDIS_URL=redis://localhost:6379/0

# LLM — Motor A (ITPlusBot) y Motor B (RAG)
# Drivers: groq | openai | ollama
AI_DRIVER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# Embeddings locales (sentence-transformers, sin API key)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Almacenamiento de documentos
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# CORS
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Seguridad / sesiones (defaults; editables desde panel admin)
API_TOKEN_EXPIRE_HOURS=24
SESSIONS_IDLE_MINUTES=30
SESSIONS_RETENTION_MONTHS=6

# Azure AD / Entra ID (inactivo hasta configurar backend + frontend)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Frontend build (Vite) — botón Microsoft solo si ambas están definidas:
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_TENANT_ID=
# VITE_AZURE_REDIRECT_URI=http://localhost:3000

# Fase 3 — Conector ERP/API (dejar vacío hasta integrar)
# ERP_API_URL=
# ERP_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
